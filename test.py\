import os
import sys
import asyncio
from telethon import TelegramClient

print("---[TEST]--- Starting Minimal Telethon Test ---")

# --- Read Variables ---
API_ID = os.environ.get("API_ID")
API_HASH = os.environ.get("API_HASH")
BOT_TOKEN = os.environ.get("BOT_TOKEN")

print(f"---[TEST]--- API_ID found: {bool(API_ID)}")
print(f"---[TEST]--- API_HASH found: {bool(API_HASH)}")
print(f"---[TEST]--- BOT_TOKEN found: {bool(BOT_TOKEN)}")

# --- Validate Variables ---
if not all([API_ID, API_HASH, BOT_TOKEN]):
    print("!!! [TEST] ERROR: One or more environment variables are missing.")
    sys.exit(1)

try:
    API_ID = int(API_ID)
except (ValueError, TypeError):
    print(f"!!! [TEST] ERROR: API_ID is not a valid number. Value was: '{API_ID}'")
    sys.exit(1)

# --- Main Test Logic ---
async def main():
    print("---[TEST]--- Initializing Client...")
    # Use in-memory session, which is correct for bots
    client = TelegramClient(None, API_ID, API_HASH)
    
    try:
        print("---[TEST]--- Connecting Client as Bot...")
        await client.start(bot_token=BOT_TOKEN)

        me = await client.get_me()
        print("\n\n✅ ✅ ✅ SUCCESS! ✅ ✅ ✅")
        print(f"---[TEST]--- Logged in successfully as: {me.first_name} (@{me.username})")
        
        await client.disconnect()
        print("---[TEST]--- Disconnected. Test finished successfully.")

    except Exception as e:
        print("\n\n❌ ❌ ❌ TEST FAILED! ❌ ❌ ❌")
        print(f"An error occurred during client.start(): {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)

# --- Run the test ---
if __name__ == "__main__":
    asyncio.run(main())
